{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": "public",
  "installCommand": null,
  "functions": {
    "api/courses.py": {
      "includeFiles": "api/_catalog.json"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/store", "destination": "/store.html" },
    { "source": "/player", "destination": "/player.html" },
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/tutorial", "destination": "/tutorial.html" },
    { "source": "/manual", "destination": "/manual.html" },
    { "source": "/instructor-dashboard", "destination": "/instructor-dashboard.html" },
    { "source": "/course-editor-enhanced", "destination": "/course-editor-enhanced.html" },
    { "source": "/course-database", "destination": "/course-database.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
