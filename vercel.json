{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/store", "destination": "/public/store.html" },
    { "source": "/player", "destination": "/public/player.html" },
    { "source": "/demo", "destination": "/public/demo.html" },
    { "source": "/tutorial", "destination": "/public/tutorial.html" },
    { "source": "/manual", "destination": "/public/manual.html" },
    { "source": "/instructor-dashboard", "destination": "/public/instructor-dashboard.html" },
    { "source": "/course-editor-enhanced", "destination": "/public/course-editor-enhanced.html" },
    { "source": "/course-database", "destination": "/public/course-database.html" },
    { "source": "/courses/:path*", "destination": "/public/courses/:path*" },
    { "source": "/templates/:path*", "destination": "/public/templates/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
